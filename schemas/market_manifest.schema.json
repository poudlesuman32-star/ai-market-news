{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/poudlesuman32-star/ai-market-news/schemas/market_manifest.schema.json",
  "title": "Iteration 16 public market artifact manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "contract_id",
    "artifact_id",
    "provider_name",
    "source_repository",
    "source_commit_sha",
    "data_file_path",
    "data_file_sha256",
    "data_format",
    "encoding",
    "calendar",
    "timezone",
    "corporate_action_adjusted",
    "regular_session_only",
    "symbol_count",
    "row_count",
    "symbols",
    "start_date",
    "end_date",
    "source_data_modified",
    "synthetic_prices_used"
  ],
  "properties": {
    "manifest_version": {"const": "1.0.0"},
    "contract_id": {"const": "iteration-16-market-source-v1"},
    "artifact_id": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "provider_name": {"type": "string", "minLength": 1},
    "source_repository": {"const": "poudlesuman32-star/ai-market-news"},
    "source_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "data_file_path": {"type": "string", "pattern": "^snapshots/[^/]+/market_prices\\.csv$"},
    "data_file_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "data_format": {"const": "csv"},
    "encoding": {"const": "utf-8"},
    "calendar": {"const": "XNYS"},
    "timezone": {"const": "America/New_York"},
    "corporate_action_adjusted": {"const": true},
    "regular_session_only": {"const": true},
    "symbol_count": {"const": 11},
    "row_count": {"type": "integer", "minimum": 11},
    "symbols": {
      "type": "array",
      "const": ["BE", "CAR", "GEV", "INTC", "MU", "NVDA", "PLTR", "POWL", "SNDK", "SPY", "VRT"]
    },
    "start_date": {"type": "string", "format": "date"},
    "end_date": {"type": "string", "format": "date"},
    "source_data_modified": {"const": false},
    "synthetic_prices_used": {"const": false},
    "notes": {"type": ["string", "null"]}
  }
}
